generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Website {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  audits    Audit[]

  @@map("websites")
}

model Audit {
  id                 Int      @id @default(autoincrement())
  websiteId          Int      @map("website_id")
  performanceScore   Int?     @map("performance_score")
  accessibilityScore Int?     @map("accessibility_score")
  bestPracticesScore Int?     @map("best_practices_score")
  seoScore           Int?     @map("seo_score")
  error              String?
  createdAt          DateTime @default(now()) @map("created_at")
  // Trimmed, real Lighthouse findings per metric (fcp/lcp/tbt/cls/si), used
  // to power the hover-diagnosis tooltip. Not the full raw report — just
  // title/description/score/displayValue for the audits relevant to each
  // metric (see _lib/lighthouse-diagnostics.ts).
  diagnostics        Json?
  // How many audits (including this one) were running concurrently at the
  // moment this one started. 1 = ran alone, clean numbers. 2+ = ran under
  // CPU contention from sibling audits — TBT/Speed Index/performance score
  // may read noisier than a solo run. Powers the "noisy result" badge.
  concurrentAudits   Int?     @map("concurrent_audits")

model Audit {
  id                 Int         @id @default(autoincrement())
  websiteId          Int         @map("website_id")
  status             AuditStatus @default(complete) @map("status")
  performanceScore   Int?        @map("performance_score")
  accessibilityScore Int?        @map("accessibility_score")
  bestPracticesScore Int?        @map("best_practices_score")
  seoScore           Int?        @map("seo_score")
  error              String?
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @default(now()) @updatedAt @map("updated_at")

  website    Website          @relation(fields: [websiteId], references: [id])
  metrics    Metric[]
  categories AuditCategory[]
  issues     AuditIssue[]

  @@map("audits")
}

model AuditCategory {
  id        Int      @id @default(autoincrement())
  auditId   Int      @map("audit_id")
  category  String
  score     Float?   @map("score")
  createdAt DateTime @default(now()) @map("created_at")

  audit  Audit        @relation(fields: [auditId], references: [id], onDelete: Cascade)
  issues AuditIssue[]

  @@map("audit_categories")
}

model AuditIssue {
  id               Int      @id @default(autoincrement())
  auditId          Int      @map("audit_id")
  categoryId       Int?     @map("category_id")
  category         String
  title            String
  description      String?
  score            Float?   @map("score")
  severity         String?
  explanation      String?
  displayValue     String?  @map("display_value")
  selector         String?
  htmlSnippet      String?  @map("html_snippet")
  recommendation   String?
  documentationUrl String?  @map("documentation_url")
  estimatedImpact  String?  @map("estimated_impact")
  createdAt        DateTime @default(now()) @map("created_at")

  audit        Audit          @relation(fields: [auditId], references: [id], onDelete: Cascade)
  categoryRef  AuditCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("audit_issues")
}

model Metric {
  id         Int      @id @default(autoincrement())
  auditId    Int      @map("audit_id")
  fcp        Float?   @map("fcp")
  lcp        Float?   @map("lcp")
  cls        Float?   @map("cls")
  tbt        Float?   @map("tbt")
  speedIndex Float?   @map("speed_index")
  tti        Float?   @map("tti")

  audit Audit @relation(fields: [auditId], references: [id])

  @@map("metrics")
}
